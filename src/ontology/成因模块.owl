<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://www.example.org/ontologies/rain-disaster-prediction#"
     xml:base="http://www.example.org/ontologies/rain-disaster-prediction"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dc="http://purl.org/dc/elements/1.1/">

    <owl:Ontology rdf:about="http://www.example.org/ontologies/rain-disaster-prediction">
        <dc:title>降水灾害预测本体 - 成因模块</dc:title>
        <dc:description>用于描述降水灾害成因的本体，包含气象成因、地形成因和设施成因三个子类</dc:description>
        <dc:creator>Ontology Builder</dc:creator>
        <dc:date>2026-05-21</dc:date>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>

    <!-- ==================== 核心类定义 ==================== -->

    <!-- 成因根类 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#成因">
        <rdfs:label>成因</rdfs:label>
        <rdfs:comment>降水灾害成因的根类</rdfs:comment>
    </owl:Class>

    <!-- 气象成因 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#气象成因">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#成因"/>
        <rdfs:label>气象成因</rdfs:label>
        <rdfs:comment>与气象条件相关的灾害成因</rdfs:comment>
    </owl:Class>

    <!-- 地形成因 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#地形成因">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#成因"/>
        <rdfs:label>地形成因</rdfs:label>
        <rdfs:comment>与地形地理条件相关的灾害成因</rdfs:comment>
    </owl:Class>

    <!-- 设施成因 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#设施成因">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#成因"/>
        <rdfs:label>设施成因</rdfs:label>
        <rdfs:comment>与基础设施状态相关的灾害成因</rdfs:comment>
    </owl:Class>

    <!-- ==================== 气象成因子类 ==================== -->

    <!-- 降雨量指标 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#降雨量指标">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象成因"/>
        <rdfs:label>降雨量指标</rdfs:label>
        <rdfs:comment>描述降雨量的相关指标</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#小时降雨量">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#降雨量指标"/>
        <rdfs:label>小时降雨量</rdfs:label>
        <rdfs:comment>1小时降雨量(分站)</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#最大小时雨量站">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#降雨量指标"/>
        <rdfs:label>最大小时雨量站</rdfs:label>
        <rdfs:comment>最大1h雨量站</rdfs:comment>
    </owl:Class>

    <!-- 气象预警 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#气象预警">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象成因"/>
        <rdfs:label>气象预警</rdfs:label>
        <rdfs:comment>气象部门发布的预警信息</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#暴雨预警">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象预警"/>
        <rdfs:label>暴雨预警</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#雷电预警">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象预警"/>
        <rdfs:label>雷电预警</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#大风预警">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象预警"/>
        <rdfs:label>大风预警</rdfs:label>
    </owl:Class>

    <!-- 气象要素 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#气象要素">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象成因"/>
        <rdfs:label>气象要素</rdfs:label>
        <rdfs:comment>温度、湿度、风速、能见度等气象要素</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#温度">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象要素"/>
        <rdfs:label>温度</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#湿度">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象要素"/>
        <rdfs:label>湿度</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#风速">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象要素"/>
        <rdfs:label>风速</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#能见度">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象要素"/>
        <rdfs:label>能见度</rdfs:label>
    </owl:Class>

    <!-- 空气质量指标 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#空气质量指标">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象成因"/>
        <rdfs:label>空气质量指标</rdfs:label>
        <rdfs:comment>空气质量相关指标</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#空气质量指数">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#空气质量指标"/>
        <rdfs:label>空气质量指数(AQI)</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#首要污染物">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#空气质量指标"/>
        <rdfs:label>首要污染物</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#空气质量指标"/>
        <rdfs:label>污染物浓度</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#PM2.5">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度"/>
        <rdfs:label>PM2.5</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#PM10">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度"/>
        <rdfs:label>PM10</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#二氧化硫">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度"/>
        <rdfs:label>SO₂</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#二氧化氮">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度"/>
        <rdfs:label>NO₂</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#一氧化碳">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度"/>
        <rdfs:label>CO</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#臭氧">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度"/>
        <rdfs:label>O₃</rdfs:label>
    </owl:Class>

    <!-- 水质监测 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#水质监测">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#气象成因"/>
        <rdfs:label>水质监测</rdfs:label>
    </owl:Class>

    <!-- ==================== 地形成因子类 ==================== -->

    <!-- 水位指标 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#水位指标">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#地形成因"/>
        <rdfs:label>水位指标</rdfs:label>
        <rdfs:comment>各类水体的水位信息</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#长江水位">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#水位指标"/>
        <rdfs:label>长江水位</rdfs:label>
        <rdfs:comment>长江武汉关水位</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#汉江水位">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#水位指标"/>
        <rdfs:label>汉江水位</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#湖泊水位">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#水位指标"/>
        <rdfs:label>湖泊水位</rdfs:label>
        <rdfs:comment>主要湖泊水位(东湖/南湖/汤逊湖/后湖/墨水湖)</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#渠道水位">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#水位指标"/>
        <rdfs:label>渠道水位</rdfs:label>
        <rdfs:comment>主要渠道水位</rdfs:comment>
    </owl:Class>

    <!-- 易积水点 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#易积水点">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#地形成因"/>
        <rdfs:label>易积水点</rdfs:label>
        <rdfs:comment>历史易积水点台账</rdfs:comment>
    </owl:Class>

    <!-- ==================== 设施成因子类 ==================== -->

    <!-- 排水设施 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#排水设施">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#设施成因"/>
        <rdfs:label>排水设施</rdfs:label>
        <rdfs:comment>排水相关基础设施</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#泵站">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#排水设施"/>
        <rdfs:label>泵站</rdfs:label>
        <rdfs:comment>排水泵站设施</rdfs:comment>
    </owl:Class>

    <!-- 桥隧设施 -->
    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#桥隧设施">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#设施成因"/>
        <rdfs:label>桥隧设施</rdfs:label>
        <rdfs:comment>桥梁和隧道设施</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#桥隧巡查记录">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#桥隧设施"/>
        <rdfs:label>桥隧巡查记录</rdfs:label>
        <rdfs:comment>桥隧巡查记录(积水/淤塞)</rdfs:comment>
    </owl:Class>

    <!-- ==================== 责任单位类 ==================== -->

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#责任单位">
        <rdfs:label>责任单位</rdfs:label>
        <rdfs:comment>负责数据采集和管理的单位</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#市水务局">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#责任单位"/>
        <rdfs:label>市水务局</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#市气象局">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#责任单位"/>
        <rdfs:label>市气象局</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#市城管委">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#责任单位"/>
        <rdfs:label>市城管委</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#市生态环境局">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#责任单位"/>
        <rdfs:label>市生态环境局</rdfs:label>
    </owl:Class>

    <!-- ==================== 指标编码类 ==================== -->

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#指标编码">
        <rdfs:label>指标编码</rdfs:label>
        <rdfs:comment>数据项的唯一编码</rdfs:comment>
    </owl:Class>

    <!-- ==================== 优先级类 ==================== -->

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#优先级">
        <rdfs:label>优先级</rdfs:label>
        <rdfs:comment>数据项的优先级</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#P0优先级">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#优先级"/>
        <rdfs:label>P0优先级</rdfs:label>
        <rdfs:comment>最高优先级</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#P2优先级">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#优先级"/>
        <rdfs:label>P2优先级</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#P3优先级">
        <rdfs:subClassOf rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#优先级"/>
        <rdfs:label>P3优先级</rdfs:label>
    </owl:Class>

    <!-- ==================== 数据项类 ==================== -->

    <owl:Class rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#数据项">
        <rdfs:label>数据项</rdfs:label>
        <rdfs:comment>具体的数据采集项</rdfs:comment>
    </owl:Class>

    <!-- ==================== 属性定义 ==================== -->

    <!-- 数据类型属性 -->
    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#指标编码值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#数据项"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>指标编码</rdfs:label>
        <rdfs:comment>数据项的编码标识</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#数据项名称">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#数据项"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>数据项名称</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#序号">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#数据项"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>序号</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#水位值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#水位指标"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>水位值</rdfs:label>
        <rdfs:comment>水位的数值(单位:米)</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#降雨量值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#降雨量指标"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>降雨量值</rdfs:label>
        <rdfs:comment>降雨量的数值(单位:毫米)</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#温度值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#温度"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>温度值</rdfs:label>
        <rdfs:comment>温度数值(单位:摄氏度)</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#湿度值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#湿度"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>湿度值</rdfs:label>
        <rdfs:comment>相对湿度(单位:%)</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#风速值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#风速"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>风速值</rdfs:label>
        <rdfs:comment>风速数值(单位:m/s)</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#能见度值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#能见度"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>能见度值</rdfs:label>
        <rdfs:comment>能见度数值(单位:km)</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#AQI值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#空气质量指数"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>AQI值</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度值">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#污染物浓度"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label>污染物浓度值</rdfs:label>
        <rdfs:comment>污染物浓度数值</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/ontologies/rain-disaster-prediction#监测时间">
        <rdfs:domain rdf:resource="http://www.example.org/ontologies/rain-disaster-prediction#数据项"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label>监测时间</rdfs:label>
